{
  "name": "@umabel/api",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only --ignore-watch node_modules --no-notify src/shared/infra/http/start/server.ts",
    "build": "tsc",
    "start": "node dist/shared/infra/http/start/server.js",
    "db:generate": "prisma generate --schema=./src/shared/infra/prisma/schema.prisma",
    "db:push": "prisma db push --schema=./src/shared/infra/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./src/shared/infra/prisma/schema.prisma",
    "test": "NODE_ENV=test jest --verbose --maxWorkers=1",
    "test:e2e": "jest --config jest-e2e.config.ts --verbose --maxWorkers=1",
    "lint": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.2",
    "multer": "1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "reflect-metadata": "^0.1.14",
    "sqlite3": "^5.1.7",
    "supertest": "^6.3.4",
    "swagger-ui-express": "^5.0.0",
    "tsyringe": "^4.8.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@umabel/eslint-config": "workspace:*",
    "@umabel/typescript-config": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.19.8",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.5",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^2.0.16",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.8",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.2",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.4"
  }
}
