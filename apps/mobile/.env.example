# API (Expo expõe apenas variáveis EXPO_PUBLIC_* no cliente)

# URL da API em produção (obrigatório para builds de release)
EXPO_PUBLIC_API_URL=https://api.triadge.com

# Timeout das requisições em milissegundos (opcional, default: 10000)
EXPO_PUBLIC_API_TIMEOUT=10000

# Desenvolvimento: porta da API local (deve bater com apps/api .env PORT)
EXPO_PUBLIC_DEV_API_PORT=3331
